CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=analytics
CLICKHOUSE_PASSWORD=analytics

DATABASE_URL=postgres://analytics:analytics@localhost:5432/analytics

# Secret used to validate session tokens from Next.js / BetterAuth
SESSION_SECRET=change-me

# Port the service listens on
PORT=3001

# Cloudflare Queue push delivery auth token (set in wrangler.toml as a secret)
QUEUE_AUTH_TOKEN=change-me

RUST_LOG=info
